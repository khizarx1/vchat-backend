{
  "name": "vchat-backend",
  "version": "1.0.0",
  "private": true,
  "description": "vchat API — Express (module-based) + Prisma + Postgres",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
